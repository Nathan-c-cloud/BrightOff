# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Next.js
.next/
out/

# Python
*.egg-info/
dist/
build/

# Logs
*.log

# Benchmark CVs — fichiers réels personnels, jamais commités
# Le dossier est tracké via .gitkeep pour que la structure soit visible
backend/scripts/benchmark_cvs/*
!backend/scripts/benchmark_cvs/.gitkeep
!backend/scripts/benchmark_cvs/README.md
# Les rapports de benchmark générés (pas commités — re-générables)
backend/scripts/benchmark_results/

# Terraform
# Le répertoire de travail local généré par "terraform init" — jamais à commiter
infrastructure/.terraform/
# Les fichiers de state contiennent l'état réel de l'infra AWS, potentiellement des secrets
infrastructure/*.tfstate
infrastructure/*.tfstate.*
# Les fichiers .tfvars contiennent les valeurs réelles (potentiellement sensibles)
# Commiter terraform.tfvars.example (doc), jamais terraform.tfvars (secrets)
infrastructure/*.tfvars
# Le lock file documente les versions exactes des providers.
# Le commiter est recommandé pour garantir la reproductibilité des déploiements en équipe.
# En projet solo MVP, c'est au choix — décommenter la ligne ci-dessous pour l'ignorer.
# infrastructure/.terraform.lock.hcl
