meta {
  name: 03 Me
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/auth/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("returns user info", function() {
    expect(res.body.email).to.be.a("string");
  });
}

docs {
  Récupère les infos du user connecté. Nécessite un JWT valide.
}
