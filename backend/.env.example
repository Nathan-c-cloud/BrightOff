# Application
APP_NAME=BrightOff
DEBUG=true

# Database (local hors docker → localhost; dans docker → postgres)
DATABASE_URL=postgresql+asyncpg://brightoff:change_me_in_local@localhost:5432/brightoff

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# AWS
AWS_REGION=eu-west-3
S3_BUCKET_NAME=brightoff-cvs-dev

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-xxx

# JWT
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth (T2-10 / T2-20 — obtenir depuis Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
