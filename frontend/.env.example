# Auth.js v5 — requis pour signer les cookies de session
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=

# URL de base du frontend (doit correspondre aux redirect URIs OAuth configurés)
NEXTAUTH_URL=http://localhost:3000

# Google OAuth 2.0 — obtenir depuis Google Cloud Console
# Redirect URI autorisée : http://localhost:3000/api/auth/callback/google
# Convention Auth.js v5 : AUTH_<PROVIDER>_<FIELD> — lues automatiquement par le provider Google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# URL du backend FastAPI (sans slash final)
# Utilisé par les Server Components et les callbacks Auth.js côté serveur
# Préfixe NEXT_PUBLIC_ = lisible côté navigateur (attention : ne met pas de secret ici)
NEXT_PUBLIC_API_URL=http://localhost:8000
